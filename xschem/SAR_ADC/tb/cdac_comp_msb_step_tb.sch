echo NEG_HALF_LSB -0.001611328125 -1 $&sample45 $&sample55 $&clk7 $&clk85 $&ainp45 $&ainn45 $&vcp45 $&vcn45 $&track_err_p $&track_err_n $&vcp7sd $&vcn7sd $&vdiff_hold $&cm_hold $&voutp10sd $&voutn10sd $&outdiff10sd $&pass_sign $&iavg_sd $&pavg_sd >> cdac_bit_weight_sweep_results.txt


* ==================================================
* ZERO-DIFFERENTIAL OBSERVATION TEST
* Not graded because comparator offset / numerical asymmetry decides
* ==================================================

alterparam VDIFF = 0

alterparam BP9_FINAL = 1.65
alterparam BP8_FINAL = 1.65
alterparam BP7_FINAL = 1.65
alterparam BP6_FINAL = 1.65
alterparam BP5_FINAL = 1.65
alterparam BP4_FINAL = 1.65
alterparam BP3_FINAL = 1.65
alterparam BP2_FINAL = 1.65
alterparam BP1_FINAL = 1.65
alterparam BP0_FINAL = 1.65

