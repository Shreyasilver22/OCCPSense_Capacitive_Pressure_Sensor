}
C {lab_pin.sym} -80 -290 2 0 {name=p25 sig_type=std_logic lab=ainn}
C {vsource.sym} -140 -450 1 0 {name=V_VINP value="dc \{VCM + VDIFF/2\}" savecurrent=false}
C {lab_pin.sym} -80 -450 2 0 {name=p26 sig_type=std_logic lab=ainp}
C {vsource.sym} -340 -550 0 0 {name=V_VSS value="dc 0" savecurrent=false}
C {lab_pin.sym} -340 -610 0 0 {name=p28 sig_type=std_logic lab=vss

}
C {vsource.sym} -340 -410 2 0 {name=V_CLK value="PULSE(0 3.3 8n 20p 20p 4n 20n)" savecurrent=false}
C {lab_pin.sym} -340 -350 3 0 {name=p29 sig_type=std_logic lab=CLK}
C {code_shown.sym} 220 -315 0 0 {name=MODELS only_toplevel=true
format="tcleval( @value )"
value="
.include /foss/pdks/gf180mcuD/libs.tech/ngspice/design.ngspice

.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice res_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice moscap_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice diode_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice cap_mim
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice mimcap_typical

.include /foss/pdks/gf180mcuD/libs.ref/gf180mcu_fd_io/spice/gf180mcu_fd_io.spice
"}
C {code.sym} 1090 -290 0 0 {name=s1
only_toplevel=true
value="
.param VDD=3.3
.param VCM=1.65
.param VDIFF=0
.param WCU=5u
.param LCU=5u
.param COUT_LOAD=20f

* Positive MSB test:
* bp9 goes high, bn9 goes low.
.param BP9_FINAL=\{VDD\}
.param BN9_FINAL=0

* All other bits stay at VCM.
.param BP8_FINAL=\{VCM\}
.param BP7_FINAL=\{VCM\}
.param BP6_FINAL=\{VCM\}
.param BP5_FINAL=\{VCM\}
.param BP4_FINAL=\{VCM\}
.param BP3_FINAL=\{VCM\}
.param BP2_FINAL=\{VCM\}
.param BP1_FINAL=\{VCM\}
.param BP0_FINAL=\{VCM\}

.param BN8_FINAL=\{VCM\}
.param BN7_FINAL=\{VCM\}
.param BN6_FINAL=\{VCM\}
.param BN5_FINAL=\{VCM\}
.param BN4_FINAL=\{VCM\}
.param BN3_FINAL=\{VCM\}
.param BN2_FINAL=\{VCM\}
.param BN1_FINAL=\{VCM\}
.param BN0_FINAL=\{VCM\}


.options savecurrents
.options reltol=1e-4 abstol=1e-12 vntol=1e-6 method=gear

.save v(sample) v(sampleb) v(CLK)
.save v(ainp) v(ainn)
.save v(vcp) v(vcn)
.save v(bp9) v(bn9)
.save v(Voutp) v(Voutn)
.save i(VDD_SRC)

.control

shell rm -f cdac_bit_weight_sweep_results.txt

echo ================================================== > cdac_bit_weight_sweep_results.txt
echo CDAC BIT-WEIGHT SWEEP RESULTS >> cdac_bit_weight_sweep_results.txt
echo ================================================== >> cdac_bit_weight_sweep_results.txt
echo Sweep type: positive differential CDAC steps >> cdac_bit_weight_sweep_results.txt
echo For each bit k: bp[k] switches VCM to VDD, bn[k] switches VCM to 0 >> cdac_bit_weight_sweep_results.txt
echo All other bottom plates stay at VCM >> cdac_bit_weight_sweep_results.txt
echo Dummy caps bpd and bnd stay at VCM >> cdac_bit_weight_sweep_results.txt
echo VDD = 3.3 V >> cdac_bit_weight_sweep_results.txt
echo VCM = 1.65 V >> cdac_bit_weight_sweep_results.txt
echo Unit cap uses cap_mim_2f0fF with WCU=5um and LCU=5um >> cdac_bit_weight_sweep_results.txt
echo Approx Cu = 2 fF/um2 * 5um * 5um = 50 fF >> cdac_bit_weight_sweep_results.txt
echo Approx total capacitance per side = 1024*50fF = 51.2 pF >> cdac_bit_weight_sweep_results.txt
echo Sample turns OFF at 5 ns >> cdac_bit_weight_sweep_results.txt
echo CDAC bottom plates switch at 6 ns >> cdac_bit_weight_sweep_results.txt
echo CDAC step measured at 7 ns >> cdac_bit_weight_sweep_results.txt
echo Comparator CLK rises at 8 ns >> cdac_bit_weight_sweep_results.txt
echo Comparator output measured at 10 ns >> cdac_bit_weight_sweep_results.txt
echo pass_weight = 1 if CDAC step error is less than 10 percent >> cdac_bit_weight_sweep_results.txt
echo pass_comp = 1 if comparator output has correct positive polarity >> cdac_bit_weight_sweep_results.txt
echo ================================================== >> cdac_bit_weight_sweep_results.txt
echo columns: BIT expected_step measured_step abs_error rel_error_percent vdiff_before vdiff_after vcp_5p5 vcn_5p5 vcp_7 vcn_7 cm_7 voutp_10 voutn_10 outdiff_10 pass_weight pass_comp iavg_0_10ns pavg_0_10ns >> cdac_bit_weight_sweep_results.txt
echo ================================================== >> cdac_bit_weight_sweep_results.txt


* ==================================================
* BIT 9 POSITIVE STEP
* ==================================================
alterparam BP9_FINAL = 3.3
alterparam BP8_FINAL = 1.65
alterparam BP7_FINAL = 1.65
alterparam BP6_FINAL = 1.65
alterparam BP5_FINAL = 1.65
alterparam BP4_FINAL = 1.65
alterparam BP3_FINAL = 1.65
alterparam BP2_FINAL = 1.65
alterparam BP1_FINAL = 1.65
alterparam BP0_FINAL = 1.65

alterparam BN9_FINAL = 0
alterparam BN8_FINAL = 1.65
alterparam BN7_FINAL = 1.65
alterparam BN6_FINAL = 1.65
alterparam BN5_FINAL = 1.65
alterparam BN4_FINAL = 1.65
alterparam BN3_FINAL = 1.65
alterparam BN2_FINAL = 1.65
alterparam BN1_FINAL = 1.65
alterparam BN0_FINAL = 1.65

reset
tran 1p 12n

meas tran vcp55 FIND v(vcp) AT=5.5n
meas tran vcn55 FIND v(vcn) AT=5.5n
let vdiff_before = vcp55 - vcn55

meas tran vcp7 FIND v(vcp) AT=7n
meas tran vcn7 FIND v(vcn) AT=7n
let vdiff_after = vcp7 - vcn7
let measured_step = vdiff_after - vdiff_before
let expected_step = 1.65
let abs_error = abs(measured_step - expected_step)
let rel_error_percent = 100*abs_error/expected_step
let cm7 = 0.5*(vcp7 + vcn7)

meas tran voutp10 FIND v(Voutp) AT=10n
meas tran voutn10 FIND v(Voutn) AT=10n
let outdiff10 = voutp10 - voutn10

let pass_weight = 0
if rel_error_percent < 10
  let pass_weight = 1
end

let pass_comp = 0
if outdiff10 > 2.5
  let pass_comp = 1
end

meas tran iavg AVG i(VDD_SRC) FROM=0n TO=10n
let pavg = abs(3.3*iavg)

echo 9 $&expected_step $&measured_step $&abs_error $&rel_error_percent $&vdiff_before $&vdiff_after $&vcp55 $&vcn55 $&vcp7 $&vcn7 $&cm7 $&voutp10 $&voutn10 $&outdiff10 $&pass_weight $&pass_comp $&iavg $&pavg >> cdac_bit_weight_sweep_results.txt


