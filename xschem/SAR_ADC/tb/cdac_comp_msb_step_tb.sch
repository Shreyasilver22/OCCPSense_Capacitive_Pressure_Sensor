alterparam BN8_FINAL = 1.65
alterparam BN7_FINAL = 1.65
alterparam BN6_FINAL = 1.65
alterparam BN5_FINAL = 1.65
alterparam BN4_FINAL = 1.65
alterparam BN3_FINAL = 1.65
alterparam BN2_FINAL = 1.65
alterparam BN1_FINAL = 1.65
alterparam BN0_FINAL = 1.65

reset
tran 1p 12n

meas tran sample45 FIND v(sample) AT=4.5n
meas tran sample55 FIND v(sample) AT=5.5n
meas tran clk7 FIND v(CLK) AT=7n
meas tran clk85 FIND v(CLK) AT=8.5n

meas tran ainp45 FIND v(ainp) AT=4.5n
meas tran ainn45 FIND v(ainn) AT=4.5n
meas tran vcp45 FIND v(vcp) AT=4.5n
meas tran vcn45 FIND v(vcn) AT=4.5n

let track_err_p = vcp45 - ainp45
let track_err_n = vcn45 - ainn45

meas tran vcp7sd FIND v(vcp) AT=7n
meas tran vcn7sd FIND v(vcn) AT=7n

let vdiff_hold = vcp7sd - vcn7sd
let cm_hold = 0.5*(vcp7sd + vcn7sd)

meas tran voutp10sd FIND v(Voutp) AT=10n
meas tran voutn10sd FIND v(Voutn) AT=10n

let outdiff10sd = voutp10sd - voutn10sd

let pass_sign = 9

meas tran iavg_sd AVG i(VDD_SRC) FROM=0n TO=10n
let pavg_sd = abs(3.3*iavg_sd)

echo ZERO 0 0 $&sample45 $&sample55 $&clk7 $&clk85 $&ainp45 $&ainn45 $&vcp45 $&vcn45 $&track_err_p $&track_err_n $&vcp7sd $&vcn7sd $&vdiff_hold $&cm_hold $&voutp10sd $&voutn10sd $&outdiff10sd $&pass_sign $&iavg_sd $&pavg_sd >> cdac_bit_weight_sweep_results.txt

echo ================================================== >> cdac_bit_weight_sweep_results.txt
echo END OF SMALL-DIFFERENTIAL SAMPLER + COMPARATOR TEST >> cdac_bit_weight_sweep_results.txt
echo PASS_SIGN: 1 correct, 0 wrong, 9 zero-diff not graded >> cdac_bit_weight_sweep_results.txt
echo Expected POS_HALF_LSB: vdiff_hold positive, Voutp high, Voutn low >> cdac_bit_weight_sweep_results.txt
echo Expected NEG_HALF_LSB: vdiff_hold negative, Voutp low, Voutn high >> cdac_bit_weight_sweep_results.txt
echo ZERO is observation only >> cdac_bit_weight_sweep_results.txt
echo ================================================== >> cdac_bit_weight_sweep_results.txt

.endc

