format="tcleval( @value )"
value="
.include /foss/pdks/gf180mcuD/libs.tech/ngspice/design.ngspice

.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice res_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice moscap_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice diode_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice cap_mim
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice mimcap_typical

.include /foss/pdks/gf180mcuD/libs.ref/gf180mcu_fd_io/spice/gf180mcu_fd_io.spice
"}
C {code.sym} 1070 -295 0 0 {name=s1
only_toplevel=true
value="
* ============================================================
* GF180 / SAR FSM + Comparator + CDAC mixed-signal testbench
* REAL DAC-switch version
* ============================================================

* Standard-cell SPICE and SAR FSM wrapper
.include /foss/pdks/gf180mcuD/libs.ref/gf180mcu_fd_sc_mcu7t5v0/spice/gf180mcu_fd_sc_mcu7t5v0.spice
.include /media/sf_LNA_chipathon/OCCPSense_Capacitive_Pressure_Sensor/rtl/sar_fsm/sar_fsm_wrapper_fixed.spice

* ------------------------------------------------------------
* Main parameters
* ------------------------------------------------------------
.param VDD=3.3
.param VCM=1.65
.param VDIFF=0.001611328125
.param WCU=5u
.param LCU=5u
.param COUT_LOAD=20f


* ============================================================
* SAR ADC POST-FIX SMALL RAMP DEBUG
* Dumps one row per VDIFF into:
*   sar_ramp_after_fix_results.txt
*
* Assumes current fixed schematic:
*   BP-side DAC vref pin -> vrefp
*   BN-side DAC vref pin -> vrefp
* ============================================================

.options reltol=1e-4 abstol=1e-12 vntol=1e-6
.options method=gear maxord=2
.options plotwinsize=0

* -----------------------------
* Save required nodes
* -----------------------------
.save v(CLK) v(RSTN) v(START)
.save v(sample) v(sampleb) v(comp_clk)
.save v(busy) v(valid)

.save v(ainp) v(ainn)
.save v(vcp) v(vcn)
.save v(vrefp) v(vrefn) v(vcm)
.save v(Voutp) v(Voutn)

.save v(C9) v(C8) v(C7) v(C6) v(C5)
.save v(C4) v(C3) v(C2) v(C1) v(C0)

.save v(dbp9) v(dbp8) v(dbp7) v(dbp6) v(dbp5)
.save v(dbp4) v(dbp3) v(dbp2) v(dbp1) v(dbp0)

.save v(dbn9) v(dbn8) v(dbn7) v(dbn6) v(dbn5)
.save v(dbn4) v(dbn3) v(dbn2) v(dbn1) v(dbn0)

.save v(bp9) v(bp8) v(bp7) v(bp6) v(bp5)
.save v(bp4) v(bp3) v(bp2) v(bp1) v(bp0)

.save v(bn9) v(bn8) v(bn7) v(bn6) v(bn5)
.save v(bn4) v(bn3) v(bn2) v(bn1) v(bn0)

.control

set noaskquit

shell rm -f sar_ramp_after_fix_results.txt

let logic_th = 1.65
let prev_code = -1
let run_index = 0
let monotonic_fail_count = 0

echo VDIFF VALID_SEEN T_DEBUG CODE C9 C8 C7 C6 C5 C4 C3 C2 C1 C0 VCP VCN VCP_MINUS_VCN VOUTP VOUTN DBP9 DBP8 DBP7 DBP6 DBP5 DBP4 DBP3 DBP2 DBP1 DBP0 DBN9 DBN8 DBN7 DBN6 DBN5 DBN4 DBN3 DBN2 DBN1 DBN0 BP9 BP8 BP7 BP6 BP5 BP4 BP3 BP2 BP1 BP0 BN9 BN8 BN7 BN6 BN5 BN4 BN3 BN2 BN1 BN0 MONOTONIC_FAIL > sar_ramp_after_fix_results.txt

* Small ramp around midscale.
foreach vdiff_val -0.020 -0.010 -0.005 -0.002 -0.001 0 0.001 0.001611328125 0.002 0.005 0.010 0.020

  alterparam VDIFF = $vdiff_val
  reset

  tran 20p 1.6u

  meas tran valid_max MAX v(valid) FROM=0n TO=1.6u

  let valid_seen = 0
  if valid_max > logic_th
    let valid_seen = 1
  end

  let t_debug = 1.55u
  if valid_seen > 0.5
    meas tran t_valid WHEN v(valid)=1.65 RISE=1
    let t_debug = t_valid + 5n
  end

  * -----------------------------
  * Code bits at debug time
  * -----------------------------
  meas tran c9v FIND v(C9) AT=$&t_debug
  meas tran c8v FIND v(C8) AT=$&t_debug
  meas tran c7v FIND v(C7) AT=$&t_debug
  meas tran c6v FIND v(C6) AT=$&t_debug
  meas tran c5v FIND v(C5) AT=$&t_debug
  meas tran c4v FIND v(C4) AT=$&t_debug
  meas tran c3v FIND v(C3) AT=$&t_debug
  meas tran c2v FIND v(C2) AT=$&t_debug
  meas tran c1v FIND v(C1) AT=$&t_debug
  meas tran c0v FIND v(C0) AT=$&t_debug

  let b9 = 0
  if c9v > logic_th
    let b9 = 1
  end

  let b8 = 0
  if c8v > logic_th
    let b8 = 1
  end

  let b7 = 0
  if c7v > logic_th
    let b7 = 1
  end

  let b6 = 0
  if c6v > logic_th
    let b6 = 1
  end

  let b5 = 0
  if c5v > logic_th
    let b5 = 1
  end

  let b4 = 0
  if c4v > logic_th
    let b4 = 1
  end

  let b3 = 0
  if c3v > logic_th
    let b3 = 1
  end

  let b2 = 0
  if c2v > logic_th
    let b2 = 1
  end

  let b1 = 0
  if c1v > logic_th
    let b1 = 1
  end

  let b0 = 0
  if c0v > logic_th
    let b0 = 1
  end

  let adc_code = 512*b9 + 256*b8 + 128*b7 + 64*b6 + 32*b5 + 16*b4 + 8*b3 + 4*b2 + 2*b1 + b0

  * -----------------------------
  * Analog values
  * -----------------------------
  meas tran vcpv   FIND v(vcp)   AT=$&t_debug
  meas tran vcnv   FIND v(vcn)   AT=$&t_debug
  meas tran voutpv FIND v(Voutp) AT=$&t_debug
  meas tran voutnv FIND v(Voutn) AT=$&t_debug

  let vdiff_cdac = vcpv - vcnv

  * -----------------------------
  * SAR DAC digital controls
  * -----------------------------
  meas tran dbp9v FIND v(dbp9) AT=$&t_debug
  meas tran dbp8v FIND v(dbp8) AT=$&t_debug
  meas tran dbp7v FIND v(dbp7) AT=$&t_debug
  meas tran dbp6v FIND v(dbp6) AT=$&t_debug
  meas tran dbp5v FIND v(dbp5) AT=$&t_debug
  meas tran dbp4v FIND v(dbp4) AT=$&t_debug
  meas tran dbp3v FIND v(dbp3) AT=$&t_debug
  meas tran dbp2v FIND v(dbp2) AT=$&t_debug
  meas tran dbp1v FIND v(dbp1) AT=$&t_debug
  meas tran dbp0v FIND v(dbp0) AT=$&t_debug

  meas tran dbn9v FIND v(dbn9) AT=$&t_debug
  meas tran dbn8v FIND v(dbn8) AT=$&t_debug
  meas tran dbn7v FIND v(dbn7) AT=$&t_debug
  meas tran dbn6v FIND v(dbn6) AT=$&t_debug
  meas tran dbn5v FIND v(dbn5) AT=$&t_debug
  meas tran dbn4v FIND v(dbn4) AT=$&t_debug
  meas tran dbn3v FIND v(dbn3) AT=$&t_debug
  meas tran dbn2v FIND v(dbn2) AT=$&t_debug
  meas tran dbn1v FIND v(dbn1) AT=$&t_debug
  meas tran dbn0v FIND v(dbn0) AT=$&t_debug

  * -----------------------------
  * Actual CDAC bottom plates
  * -----------------------------
  meas tran bp9v FIND v(bp9) AT=$&t_debug
  meas tran bp8v FIND v(bp8) AT=$&t_debug
  meas tran bp7v FIND v(bp7) AT=$&t_debug
  meas tran bp6v FIND v(bp6) AT=$&t_debug
  meas tran bp5v FIND v(bp5) AT=$&t_debug
  meas tran bp4v FIND v(bp4) AT=$&t_debug
  meas tran bp3v FIND v(bp3) AT=$&t_debug
  meas tran bp2v FIND v(bp2) AT=$&t_debug
  meas tran bp1v FIND v(bp1) AT=$&t_debug
  meas tran bp0v FIND v(bp0) AT=$&t_debug

  meas tran bn9v FIND v(bn9) AT=$&t_debug
  meas tran bn8v FIND v(bn8) AT=$&t_debug
  meas tran bn7v FIND v(bn7) AT=$&t_debug
  meas tran bn6v FIND v(bn6) AT=$&t_debug
  meas tran bn5v FIND v(bn5) AT=$&t_debug
  meas tran bn4v FIND v(bn4) AT=$&t_debug
  meas tran bn3v FIND v(bn3) AT=$&t_debug
  meas tran bn2v FIND v(bn2) AT=$&t_debug
  meas tran bn1v FIND v(bn1) AT=$&t_debug
  meas tran bn0v FIND v(bn0) AT=$&t_debug

  * -----------------------------
  * Monotonic check
  * -----------------------------
  let monotonic_fail = 0
  if run_index > 0
    if adc_code < prev_code
      let monotonic_fail = 1
      let monotonic_fail_count = monotonic_fail_count + 1
    end
  end

  echo $vdiff_val $&valid_seen $&t_debug $&adc_code $&b9 $&b8 $&b7 $&b6 $&b5 $&b4 $&b3 $&b2 $&b1 $&b0 $&vcpv $&vcnv $&vdiff_cdac $&voutpv $&voutnv $&dbp9v $&dbp8v $&dbp7v $&dbp6v $&dbp5v $&dbp4v $&dbp3v $&dbp2v $&dbp1v $&dbp0v $&dbn9v $&dbn8v $&dbn7v $&dbn6v $&dbn5v $&dbn4v $&dbn3v $&dbn2v $&dbn1v $&dbn0v $&bp9v $&bp8v $&bp7v $&bp6v $&bp5v $&bp4v $&bp3v $&bp2v $&bp1v $&bp0v $&bn9v $&bn8v $&bn7v $&bn6v $&bn5v $&bn4v $&bn3v $&bn2v $&bn1v $&bn0v $&monotonic_fail >> sar_ramp_after_fix_results.txt

  let prev_code = adc_code
  let run_index = run_index + 1

end

echo ================================================== >> sar_ramp_after_fix_results.txt
echo RAMP_SUMMARY >> sar_ramp_after_fix_results.txt
echo number_of_points = $&run_index >> sar_ramp_after_fix_results.txt
echo monotonic_fail_count = $&monotonic_fail_count >> sar_ramp_after_fix_results.txt
echo Expected_after_fix: code should move monotonically with VDIFF. >> sar_ramp_after_fix_results.txt
echo Near VDIFF=0, code should be close to 511 or 512. >> sar_ramp_after_fix_results.txt
echo ================================================== >> sar_ramp_after_fix_results.txt

echo ==================================================
echo SAR post-fix ramp test complete.
echo Results written to sar_ramp_after_fix_results.txt
echo ==================================================

.endc

"}
