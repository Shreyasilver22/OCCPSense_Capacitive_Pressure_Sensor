.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice cap_mim
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice mimcap_typical

.include /foss/pdks/gf180mcuD/libs.ref/gf180mcu_fd_io/spice/gf180mcu_fd_io.spice
"}
C {code.sym} -570 -1020 0 0 {name=s1
only_toplevel=true
value="
.param VDD=3.3
.param VCM=1.65
.param VCM_FOLDED=2.40

.param VB1=0.58
.param VB2=2.637
.param VB3=2.25
.param VB4=1.15

.param VBIAS_CMFB=0.82
.param VBIAS_CMFB_FLD=2.55

.param Cn=500f
.param Rn=8k
.param COUT_LOAD=200f

.param CCMFB=50p
.param CCMFB_FLD=1p

.options reltol=1e-4 abstol=1e-12 vntol=1e-6
.options gmin=1e-12
.options plotwinsize=0
.options method=gear maxord=2

.nodeset V(voutp)=1.641
.nodeset V(voutn)=1.641
.nodeset V(vbias_out)=0.866
.nodeset V(vbias_drv)=0.866
.nodeset V(va)=2.401
.nodeset V(vb)=2.401
.nodeset V(vb5)=0.716
.nodeset V(net8)=0.576
.nodeset V(net9)=3.194

.control

set noaskquit
set measdgt=8
save all

shell rm -f outcmfb_loop_report.txt
shell rm -f outcmfb_loop_response.txt

echo ================================================== > outcmfb_loop_report.txt
echo OUTPUT CMFB LOOP TEST >> outcmfb_loop_report.txt
echo ================================================== >> outcmfb_loop_report.txt

op

let voutcm_op     = 0.5*(v(voutp)+v(voutn))
let out_cm_err    = voutcm_op-1.65
let va_cm_op      = 0.5*(v(va)+v(vb))
let folded_cm_err = va_cm_op - v(vcm_ref_folded)
let idd_op        = -i(VDD_SRC)
let pdc_op        = 3.3*idd_op

echo ---------------- OP CHECK ---------------- >> outcmfb_loop_report.txt
echo VOUTP=$&v(voutp) >> outcmfb_loop_report.txt
echo VOUTN=$&v(voutn) >> outcmfb_loop_report.txt
echo VOUTCM=$&voutcm_op >> outcmfb_loop_report.txt
echo OUT_CM_ERR=$&out_cm_err >> outcmfb_loop_report.txt

echo VBIAS_OUT=$&v(vbias_out) >> outcmfb_loop_report.txt
echo VBIAS_DRV=$&v(vbias_drv) >> outcmfb_loop_report.txt
echo VA=$&v(va) >> outcmfb_loop_report.txt
echo VB=$&v(vb) >> outcmfb_loop_report.txt
echo VA_CM=$&va_cm_op >> outcmfb_loop_report.txt

echo FOLDED_CM_ERR=$&folded_cm_err >> outcmfb_loop_report.txt
echo IDD=$&idd_op >> outcmfb_loop_report.txt
echo PDC=$&pdc_op >> outcmfb_loop_report.txt
echo -------------------------------------------------- >> outcmfb_loop_report.txt

ac dec 200 1 1G

let outcmfb_inj          = v(vbias_drv)-v(vbias_out)

let outcmfb_return_ratio = -v(vbias_out)/(outcmfb_inj+1e-30)

let outcmfb_loop         = outcmfb_return_ratio/(1-outcmfb_return_ratio+1e-30)
let outcmfb_loop_db      = 20*log10(mag(outcmfb_loop)+1e-30)

let outcmfb_phase_rad    = cph(outcmfb_loop)
let outcmfb_phase_deg    = 57.2957795*outcmfb_phase_rad

meas ac OUTCMFB_GAIN_1HZ_DB  find outcmfb_loop_db at=1
meas ac OUTCMFB_PHASE_1HZ    find outcmfb_phase_deg at=1
meas ac OUTCMFB_UGF          when outcmfb_loop_db=0 fall=1
meas ac OUTCMFB_PHASE_UGF    find outcmfb_phase_deg when outcmfb_loop_db=0 fall=1

let outcmfb_phase_ugf_wrapped = outcmfb_phase_ugf

while outcmfb_phase_ugf_wrapped < -180
  let outcmfb_phase_ugf_wrapped = outcmfb_phase_ugf_wrapped + 360
end

while outcmfb_phase_ugf_wrapped > 180
  let outcmfb_phase_ugf_wrapped = outcmfb_phase_ugf_wrapped - 360
end

let OUTCMFB_PM_RAW = 180 + outcmfb_phase_ugf
let OUTCMFB_PM_WRAPPED = 180 + outcmfb_phase_ugf_wrapped

meas ac OUTCMFB_GAIN_10K     find outcmfb_loop_db at=10k
meas ac OUTCMFB_GAIN_100K    find outcmfb_loop_db at=100k
meas ac OUTCMFB_GAIN_1MEG    find outcmfb_loop_db at=1Meg
meas ac OUTCMFB_PHASE_10K    find outcmfb_phase_deg at=10k
meas ac OUTCMFB_PHASE_100K   find outcmfb_phase_deg at=100k
meas ac OUTCMFB_PHASE_1MEG   find outcmfb_phase_deg at=1Meg

echo ---------------- OUTPUT CMFB LOOP RESULTS ---------------- >> outcmfb_loop_report.txt
echo LOOP_GAIN_1HZ_DB=$&outcmfb_gain_1hz_db >> outcmfb_loop_report.txt
echo PHASE_1HZ_DEG=$&outcmfb_phase_1hz >> outcmfb_loop_report.txt
echo UGF_HZ=$&outcmfb_ugf >> outcmfb_loop_report.txt
echo PHASE_AT_UGF_DEG=$&outcmfb_phase_ugf >> outcmfb_loop_report.txt
echo PHASE_MARGIN_DEG=$&OUTCMFB_PM >> outcmfb_loop_report.txt
echo GAIN_10K_DB=$&outcmfb_gain_10k PHASE_10K_DEG=$&outcmfb_phase_10k >> outcmfb_loop_report.txt
echo GAIN_100K_DB=$&outcmfb_gain_100k PHASE_100K_DEG=$&outcmfb_phase_100k >> outcmfb_loop_report.txt
echo GAIN_1MEG_DB=$&outcmfb_gain_1meg PHASE_1MEG_DEG=$&outcmfb_phase_1meg >> outcmfb_loop_report.txt
echo PHASE_AT_UGF_RAW_DEG=$&outcmfb_phase_ugf >> outcmfb_loop_report.txt
echo PHASE_AT_UGF_WRAPPED_DEG=$&outcmfb_phase_ugf_wrapped >> outcmfb_loop_report.txt
echo PHASE_MARGIN_RAW_DEG=$&OUTCMFB_PM_RAW >> outcmfb_loop_report.txt
echo PHASE_AT_UGF_WRAPPED_DEG=$&outcmfb_phase_ugf_wrapped >> outcmfb_loop_report.txt
echo PHASE_MARGIN_WRAPPED_DEG=$&OUTCMFB_PM_WRAPPED >> outcmfb_loop_report.txt
echo PHASE_MARGIN_DEG=$&OUTCMFB_PM >> outcmfb_loop_report.txt
echo -------------------------------------------------- >> outcmfb_loop_report.txt

wrdata outcmfb_loop_response.txt outcmfb_loop_db outcmfb_phase_deg outcmfb_return_ratio

print outcmfb_gain_1hz_db outcmfb_phase_1hz
print outcmfb_ugf outcmfb_phase_ugf OUTCMFB_PM

echo Done output CMFB loop test.

.endc
"
}
